            },
            "element": {
                "type": "plain_text_input",
                "action_id": "today_input",
                "multiline": true
            }
        },
        {
            "type": "input",
            "block_id": "blockers_block",
            "label": {
                "type": "plain_text",
                "text": "¿Tienes bloqueos?"
            },
            "element": {
                "type": "plain_text_input",
                "action_id": "blockers_input",
                "multiline": true
