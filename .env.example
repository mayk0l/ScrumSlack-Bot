# === App ===
APP_ENV=development
APP_DEBUG=true
APP_PORT=3000

# === Database ===
DATABASE_URL=postgresql+asyncpg://scrum_bot:scrum_bot_pass@db:5432/scrum_bot_db

# === Slack ===
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token

# === GitHub ===
GITHUB_TOKEN=ghp_your_github_token
GITHUB_DEFAULT_ORG=your-org

# === OpenRouter (AI) ===
OPENROUTER_API_KEY=sk-or-your-key
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# === Groq (AI) ===
GROQ_API_KEY=gsk_your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile

# === Standup Config ===
STANDUP_CHANNEL_ID=C0123456789
STANDUP_TIME=09:00
SUMMARY_TIME=17:00
TIMEZONE=America/Santiago

# === Jobs periódicos (minutos; 0 desactiva) ===
GITHUB_SYNC_INTERVAL_MINUTES=30
RISK_DETECTION_INTERVAL_MINUTES=60

# === Excel ===
EXCEL_FILE_PATH=project_tracking.xlsx
